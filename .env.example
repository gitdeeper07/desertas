# DESERTAS Environment Variables
# Copy this file to .env and fill in your values

# Site Configuration
SITE_NAME=DESERTAS
SITE_URL=https://desertas.netlify.app
VERSION=1.0.0

# API Configuration
API_BASE_URL=https://desertas.netlify.app/api/v1
API_TIMEOUT=30000

# Feature Flags
ENABLE_DASHBOARD=true
ENABLE_REPORTS=true
ENABLE_DOCS=true
ENABLE_MONITORING=true
ENABLE_ALERTS=true

# Map Configuration
MAP_CENTER_LAT=20.0
MAP_CENTER_LNG=0.0
MAP_ZOOM=2

# Default Thresholds
DEFAULT_DRGIS_THRESHOLD=0.48
RN_PULSE_THRESHOLD=3.0
HE_RATIO_THRESHOLD=0.5

# Station Configuration
DEFAULT_CRATON=saharan
STATIONS_COUNT=36

# Contact
AUTHOR_EMAIL=gitdeeper@gmail.com
AUTHOR_ORCID=0009-0003-8903-0029

# API Keys (set these in production)
SUPABASE_URL=
SUPABASE_ANON_KEY=
MAPBOX_TOKEN=
