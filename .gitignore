config/local.yaml
config/*.local.yaml
*.local
*.secret
secrets/
.env.local
.env.*.local

# Field data
data/field/
data/raw/
data/processed/
data/temp/
data/cache/
data/uploads/
data/backups/
data/archive/

# Model checkpoints
models/checkpoints/
models/*.h5
models/*.pth
models/*.pt
models/*.pkl
models/*.joblib
models/*.onnx
models/*.tflite

# Dashboard build
dashboard/dist/
dashboard/build/
