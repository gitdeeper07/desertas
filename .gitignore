*.p12
*.pfx

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.cache
*.lock

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Termux specific
.storage/
.termux/

# Keep directory structure but ignore contents
data/field/*
!data/field/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
logs/*
!logs/.gitkeep
backups/*
!backups/.gitkeep

