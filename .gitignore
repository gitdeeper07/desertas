# Documentation
docs/_build/
docs/build/
docs/source/generated/
site/

# Docker
.dockerignore
docker-compose.override.yml
*.pid
*.sock

# SSL certificates
*.crt
*.key
*.pem
ssl/

# Backup files
*.bak
*.backup
backups/

# Environment files
.env
.env.production
.env.development
.env.test
.flaskenv

# Secrets
secrets.yaml
secrets.yml
credentials.json
