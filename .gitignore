.coverage
htmlcov/
.coverage.*
*.cover
*.py,cover
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/
*.orig

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST
*.tar.gz
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

